<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HTML5 Semantic Tags Demo</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
        }
        header, footer {
            background: #333;
            color: white;
            padding: 10px;
            text-align: center;
        }
        nav {
            background: #555;
            padding: 10px;
        }
        nav a {
            color: white;
            margin: 10px;
            text-decoration: none;
        }
        main {
            display: flex;
            padding: 15px;
        }
        section {
            flex: 3;
            margin-right: 10px;
        }
        aside {
            flex: 1;
            background: #f4f4f4;
            padding: 10px;
        }
        article {
            background: #e2e2e2;
            margin-bottom: 10px;
            padding: 10px;
        }
        figure {
            text-align: center;
        }
        footer {
            margin-top: 10px;
        }
        .highlight {
            color: red;
            font-weight: bold;
        }
    </style>
</head>
<body>

    <header>
        <h1>My Website Header</h1>
    </header>

    <nav>
        <a href="#">Home</a>
        <a href="#">About</a>
        <a href="#">Contact</a>
    </nav>

    <main>
        <section>
            <article>
                <h2>Article Title</h2>
                <p>This is an <span class="highlight">important</span> article using semantic tags.</p>

                <figure>
                    <img src="https://via.placeholder.com/150" alt="Sample Image">
                    <figcaption>Sample Image Caption</figcaption>
                </figure>
            </article>

            <article>
                <h2>Another Article</h2>
                <p>This is another article inside a section.</p>
            </article>
        </section>

        <aside>
            <h3>Sidebar</h3>
            <p>This is content inside the aside tag.</p>
        </aside>
    </main>

    <div style="padding: 10px; background: #ddd;">
        <p>This is a div container used for grouping content.</p>
    </div>

    <footer>
        <p>&copy; 2026 My Website Footer</p>
    </footer>

</body>
</html>
